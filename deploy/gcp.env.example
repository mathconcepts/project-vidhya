# ============================================================
# EduGenius — GCP Cloud Run Environment
# ============================================================
# Copy to .env.gcp and fill in your values.
# Sensitive values should be stored in GCP Secret Manager.
# Used by: deploy-gcp.sh
# ============================================================

# ── GCP Project ───────────────────────────────────────────────
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=asia-south1          # Mumbai — low latency for India
GCP_SERVICE_NAME=edugenius

# ── Artifact Registry ─────────────────────────────────────────
ARTIFACT_REGISTRY_REPO=edugenius
IMAGE_TAG=latest

# ── Cloud SQL (Postgres) ──────────────────────────────────────
# Format: projects/PROJECT/locations/REGION/instances/INSTANCE_NAME
CLOUD_SQL_INSTANCE=projects/your-project-id/locations/asia-south1/instances/edugenius-db
# Connection string — store in Secret Manager
# DATABASE_URL=postgresql://postgres:password@/edugenius?host=/cloudsql/your-project:asia-south1:edugenius-db

# ── Cloud Storage ─────────────────────────────────────────────
GCS_BUCKET=your-gcp-project-id-edugenius-assets

# ── Memorystore Redis (optional) ──────────────────────────────
# REDIS_URL=redis://10.x.x.x:6379   # internal IP of Memorystore

# ── AI / LLM Keys ─────────────────────────────────────────────
# Store in Secret Manager:
# gcloud secrets create GEMINI_API_KEY --data-file=-
GEMINI_API_KEY=store_in_secret_manager
ANTHROPIC_API_KEY=store_in_secret_manager

# ── Cloud Run Scaling ─────────────────────────────────────────
CLOUD_RUN_MIN_INSTANCES=0       # Scale to zero (cheapest)
CLOUD_RUN_MAX_INSTANCES=10      # Max concurrency cap

# ── Application ───────────────────────────────────────────────
NODE_ENV=production
LOG_LEVEL=info
PORT=3000                       # Cloud Run uses 3000 by default
CORS_ORIGIN=https://edugenius-ui.netlify.app
ENABLE_BATCH_RUNNER=true        # Cloud Scheduler triggers batch endpoints
