# EduGenius Frontend Environment Variables
# Copy this to .env.local for development, or set on Netlify/Vercel dashboard

# ── AI Provider (choose one or more) ─────────────────────────────────────────

# Google Gemini (recommended — free tier available, fast, great for India)
# Get key at: https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# Anthropic Claude (optional — premium quality, requires backend proxy)
VITE_ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI GPT (optional)
VITE_OPENAI_API_KEY=your_openai_api_key_here

# ── Self-hosted Backend (optional — recommended for production) ───────────────
# If set, ALL AI calls route through your backend (more secure, no keys in browser)
# Example: https://api.yourdomain.com
VITE_API_BASE_URL=

# ── Feature Flags ─────────────────────────────────────────────────────────────

# App name shown in browser tab
VITE_APP_NAME=EduGenius

# Analytics (optional)
VITE_GA4_MEASUREMENT_ID=G-XXXXXXXXXX
VITE_POSTHOG_KEY=

# Payments (Stripe public key — safe to expose)
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_...
VITE_RAZORPAY_KEY_ID=rzp_live_...

# ── Priority order ────────────────────────────────────────────────────────────
# 1. VITE_API_BASE_URL (backend proxy — most secure)
# 2. VITE_GEMINI_API_KEY (direct to Gemini)  
# 3. VITE_ANTHROPIC_API_KEY (needs CORS proxy)
# 4. No keys → Demo mode (mock responses)
