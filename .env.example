# ==============================================================================
# Project Vidhya — environment variables
# ==============================================================================
# Copy to .env and fill in what you need. Most are optional — the demo path
# (`npm run demo:setup` then `npm run demo:start`) works with NONE of these
# set. JWT_SECRET is the only thing that must be set for any non-demo
# deployment.
#
# Variables are grouped by what they enable. Anything not set degrades
# gracefully — the dependent feature returns a clear error rather than
# crashing.
# ==============================================================================


# ------------------------------------------------------------------------------
# REQUIRED for any non-demo deployment
# ------------------------------------------------------------------------------

# Minimum 16 characters. Used to sign session JWTs. The demo seeder uses a
# default placeholder; production deployments MUST set their own. Render
# autogenerates one if you deploy via render.yaml.
JWT_SECRET=replace-me-min-16-chars-or-jwt-init-fails


# ------------------------------------------------------------------------------
# REQUIRED for chat / lesson generation (anything that calls an LLM)
# ------------------------------------------------------------------------------
# Without these, /api/chat returns 503 with a clear message. The demo seed,
# planning, exam, and content-library reads all work without any LLM key.

# Google Gemini — primary chat + reasoner backend. Free tier sufficient for
# most deployments. Get one at https://aistudio.google.com/
GEMINI_API_KEY=

# Anthropic / OpenAI — alternative LLM providers. Not used by the chat path
# today (it's hard-wired to Gemini); these are read by src/llm/ for any
# code path that opts into the abstraction layer.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=


# ------------------------------------------------------------------------------
# OPTIONAL — math verification
# ------------------------------------------------------------------------------
# Without WOLFRAM_APP_ID, the wolfram source in content-studio returns null
# (orchestrator falls through). The chat path's Wolfram-verified badge stays
# off. Both degrade silently. Get a free key at https://products.wolframalpha.com/api

WOLFRAM_APP_ID=


# ------------------------------------------------------------------------------
# OPTIONAL — Google sign-in
# ------------------------------------------------------------------------------
# Without these, /auth/google returns 503. JWT-based auth still works for
# demo seed and admin-created users. Set via Google Cloud Console.

GOOGLE_OAUTH_CLIENT_ID=


# ------------------------------------------------------------------------------
# OPTIONAL — multi-channel delivery (Telegram, WhatsApp)
# ------------------------------------------------------------------------------
# Without these, the channels module shows the channel as 'not configured'
# and refuses to send. Web chat works regardless. See DEPLOY.md for setup.

TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_GROUP_IDS=

WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=


# ------------------------------------------------------------------------------
# OPTIONAL — Postgres (for production-grade GBrain student model)
# ------------------------------------------------------------------------------
# The system is designed to run WITHOUT a database. The default path is
# flat-file persistence at .data/ (users, plans, vectors, teaching turns,
# content-library additions, content-studio drafts, all JSONL).
#
# Postgres becomes useful only if:
#   - You're running multiple backend processes that need to share state
#     (the flat-file store assumes single-process)
#   - You want a separate analytics surface that can JOIN against student
#     data (the flat-file store doesn't support queries)
#   - You're under regulatory load (GDPR, FERPA) that wants ACID writes
#
# Most deployments don't need it. The codebase reads DATABASE_URL only in
# src/gbrain/student-model.ts — feature degrades cleanly when missing
# (chat works, plans work, library works, studio works; only the
# attempt-insight mastery-delta path needs it).

DATABASE_URL=


# ------------------------------------------------------------------------------
# OPTIONAL — feature flags
# ------------------------------------------------------------------------------
# Each module's flags are read once at boot. Server restart required to
# flip. Surfaced in /api/orchestrator/features.

# Auth module flags
VIDHYA_AUTH_GOOGLE_OIDC=
VIDHYA_AUTH_DEMO_SEED=
VIDHYA_AUTH_PARENT_ROLE=
VIDHYA_AUTH_INSTITUTION_ROLE=

# Content-library: allow teacher+ (not just admin) to POST runtime
# additions. Default off — opens up a submission surface that needs
# moderation we haven't built. Flip on only for trusted-contributor
# deployments.
VIDHYA_CONTENT_LIBRARY_USER_AUTHORING=


# ------------------------------------------------------------------------------
# OPTIONAL — operations
# ------------------------------------------------------------------------------

# Where the server binds. Defaults to 8080.
PORT=

# For frontend → backend communication when they're on different domains.
# Set to your backend's public URL (e.g. https://your-app.onrender.com)
PUBLIC_URL=

# Suppress stderr logging during smoke tests / CI. Off in production.
VIDHYA_LOG_STDERR=


# ------------------------------------------------------------------------------
# What's deliberately NOT in this file
# ------------------------------------------------------------------------------
# - REDIS_URL — the system has no Redis dependency
# - SMTP / email service — the system uses no email
# - SSL cert paths — handled by the reverse proxy (Render / Netlify)
# - Per-user subscription / billing keys — no monetization surface yet
#
# If you see a stale reference to any of those elsewhere in the codebase,
# please open an issue.
