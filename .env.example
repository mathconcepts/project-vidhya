# ============================================================================
# EduGenius v2.0 - Environment Configuration
# ============================================================================
# Copy this file to .env and fill in your values
# Minimum required: GEMINI_API_KEY, DATABASE_URL, JWT_SECRET
# ============================================================================

# ============================================================================
# 🧠 LLM PROVIDERS (At least 1 required)
# ============================================================================

# Google Gemini (PRIMARY) ⭐ REQUIRED
GEMINI_API_KEY=your_gemini_api_key_here
# Get from: https://aistudio.google.com/

# Anthropic Claude (QUALITY FALLBACK)
ANTHROPIC_API_KEY=
# Get from: https://console.anthropic.com/

# OpenAI (TERTIARY FALLBACK)
OPENAI_API_KEY=
# Get from: https://platform.openai.com/

# Groq (FAST INFERENCE)
GROQ_API_KEY=
# Get from: https://console.groq.com/

# DeepSeek (REASONING)
DEEPSEEK_API_KEY=
# Get from: https://platform.deepseek.com/

# Mistral AI
MISTRAL_API_KEY=
# Get from: https://console.mistral.ai/

# Together AI (OPEN SOURCE MODELS)
TOGETHER_API_KEY=
# Get from: https://www.together.ai/

# OpenRouter (UNIFIED API)
OPENROUTER_API_KEY=
OPENROUTER_SITE_URL=https://edugenius.in
OPENROUTER_SITE_NAME=EduGenius
# Get from: https://openrouter.ai/

# Ollama (LOCAL - FREE)
OLLAMA_URL=http://localhost:11434

# ============================================================================
# 🗄️ DATABASE (Required)
# ============================================================================

# PostgreSQL ⭐ REQUIRED
DATABASE_URL=postgres://user:password@host:5432/edugenius
# Quick setup: https://neon.tech/ (free)

# Individual connection params (alternative to DATABASE_URL)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=edugenius
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_SSL=false

# Redis (Optional but recommended)
REDIS_URL=redis://localhost:6379
# Or individual params:
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ============================================================================
# 🔐 AUTHENTICATION (Required)
# ============================================================================

# JWT ⭐ REQUIRED - Generate with: openssl rand -hex 32
JWT_SECRET=generate_a_64_character_random_string_here_for_security

# Site URL
SITE_URL=http://localhost:3000

# Google OAuth (Recommended)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback
# Get from: https://console.cloud.google.com/apis/credentials

# Microsoft OAuth
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT_URI=http://localhost:3000/auth/microsoft/callback

# Apple OAuth
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=
APPLE_REDIRECT_URI=http://localhost:3000/auth/apple/callback

# ============================================================================
# 💳 PAYMENTS
# ============================================================================

# Stripe (International)
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Get from: https://dashboard.stripe.com/

# Razorpay (India)
RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
# Get from: https://dashboard.razorpay.com/

# ============================================================================
# 📧 EMAIL
# ============================================================================

# SendGrid (Recommended)
SENDGRID_API_KEY=SG...
# Get from: https://app.sendgrid.com/

# Resend (Alternative)
RESEND_API_KEY=re_...
# Get from: https://resend.com/

# SMTP (Fallback)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ============================================================================
# 💬 CHAT CHANNELS
# ============================================================================

# WhatsApp Business
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=
# Get from: https://business.facebook.com/

# Telegram Bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_GROUP_IDS=
# Comma-separated chat IDs, e.g. -1001234567890,-1009876543210
CRON_SECRET=
# Secret for authenticating cron requests — generate with: openssl rand -hex 32
# Get bot token from: @BotFather on Telegram

# Google Meet (uses Google OAuth)
GOOGLE_REFRESH_TOKEN=

# ============================================================================
# ✅ CONTENT VERIFICATION
# ============================================================================

# Wolfram Alpha ⭐ RECOMMENDED
WOLFRAM_APP_ID=
# Get from: https://developer.wolframalpha.com/

# SymPy Cloud (Optional)
SYMPY_ENDPOINT=
SYMPY_API_KEY=

# ============================================================================
# 🔍 VECTOR STORE
# ============================================================================

# Pinecone
PINECONE_API_KEY=
PINECONE_ENVIRONMENT=us-east1-gcp
PINECONE_INDEX=edugenius
# Get from: https://app.pinecone.io/

# Qdrant (Alternative)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=edugenius

# Provider selection
VECTOR_STORE_PROVIDER=memory
# Options: pinecone, qdrant, memory

# ============================================================================
# 📊 ANALYTICS
# ============================================================================

# Google Analytics 4
GA4_MEASUREMENT_ID=G-XXXXXXXXXX
GA4_API_SECRET=
# Get from: https://analytics.google.com/

# Mixpanel
MIXPANEL_TOKEN=
MIXPANEL_API_SECRET=
# Get from: https://mixpanel.com/

# ============================================================================
# 🌐 INFRASTRUCTURE
# ============================================================================

# Environment
NODE_ENV=development
PORT=3000

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# ============================================================================
# 🚀 QUICK START
# ============================================================================
# 
# MINIMUM TO RUN (just 3 values):
# 1. GEMINI_API_KEY     → https://aistudio.google.com/
# 2. DATABASE_URL       → https://neon.tech/ (free)
# 3. JWT_SECRET         → Run: openssl rand -hex 32
#
# Then: npm install && npm run dev
# ============================================================================
