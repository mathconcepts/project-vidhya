# ============================================================
# EduGenius — Railway PaaS Environment
# ============================================================
# Variables to push to Railway via:
#   ./scripts/deploy-railway.sh --env-push
#
# NOTE: DATABASE_URL, REDIS_URL, and PORT are AUTO-INJECTED
# by Railway plugins — do NOT set them here.
# ============================================================

# ── Application ──────────────────────────────────────────────
NODE_ENV=production
LOG_LEVEL=info
# Railway auto-injects PORT — don't override it

# ── Frontend CORS ─────────────────────────────────────────────
# Set to your Railway frontend URL or Netlify URL
CORS_ORIGIN=https://edugenius-ui.netlify.app

# ── AI / LLM Keys ────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Media Storage ─────────────────────────────────────────────
CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name

# ── Email ─────────────────────────────────────────────────────
# SMTP_HOST=smtp.resend.com
# SMTP_PORT=465
# SMTP_USER=resend
# SMTP_PASS=your_resend_api_key
# EMAIL_FROM=noreply@edugenius.io

# ── Analytics ─────────────────────────────────────────────────
# POSTHOG_API_KEY=phc_...

# ── Feature Flags ─────────────────────────────────────────────
ENABLE_BATCH_RUNNER=true
