# .env.deploy.example — environment variables for the Vidhya demo
#
# On Render, render.yaml declares these. This file documents them for
# deployments elsewhere (Fly, Docker Hub, your own host).
#
# Copy to .env.deploy, fill in, and:
#   docker run --env-file .env.deploy -p 8080:8080 \
#     -v vidhya-data:/app/.data vidhya-demo
#
# Or export them before `npm run demo:start` for local.

# ─── Required ─────────────────────────────────────────────────────────

# JWT_SECRET — at least 16 chars. Random 32-char recommended:
#   export JWT_SECRET=$(openssl rand -hex 16)
JWT_SECRET=

# Port the server binds to. 8080 matches the Dockerfile default.
PORT=8080

NODE_ENV=production

# ─── BYOK LLM (one key unlocks AI tutor / Snap / explainers) ──────────

# Get a free Gemini key: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Or Anthropic (paid): https://console.anthropic.com
ANTHROPIC_API_KEY=

# Or OpenAI (paid): https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Which provider to prefer. Must match a key above. Valid values:
#   gemini | anthropic | openai
VIDHYA_LLM_PRIMARY_PROVIDER=

# ─── Optional — maths verification ────────────────────────────────────

# Get a free Wolfram key: https://products.wolframalpha.com/api
WOLFRAM_APP_ID=

# ─── Optional — channel delivery ──────────────────────────────────────

# Telegram: /newbot with @BotFather in Telegram
TELEGRAM_BOT_TOKEN=

# WhatsApp (Meta for Developers → WhatsApp Business API)
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=

# ─── Optional — set after first deploy for channel webhooks ──────────

# Your live URL, e.g. https://vidhya-demo-abc123.onrender.com
# Needed by Telegram bot webhook setup + WhatsApp verification URL.
PUBLIC_URL=
