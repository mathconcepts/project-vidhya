# =============================================================================
# .dockerignore — keep host-side dev artifacts out of the image build context.
# =============================================================================
# Without this file, every file in the repo (including stale demo tokens,
# node_modules, .git, build outputs) gets sent to the Docker daemon as build
# context, slowing builds and leaking host state into the image.
#
# Anything in this list is invisible to the Dockerfile's COPY instructions.
# Keep this file in sync with .gitignore where the rationale overlaps.
# =============================================================================

# --- VCS / IDE -----------------------------------------------------------------
.git
.gitignore
.vscode
.idea
*.swp
*.swo

# --- node_modules — installed in-container, never copy from host -------------
node_modules
frontend/node_modules

# --- Build outputs — produced inside the build stage, never copy from host ---
dist
build
frontend/dist
*.tsbuildinfo

# --- Local-only docker-compose overrides --------------------------------------
docker-compose.override.yml
docker-compose.override.yaml

# --- Local env / secrets ------------------------------------------------------
.env
.env.*
!.env.example

# --- Demo runtime artifacts: regenerated inside the container -----------------
# demo/demo-tokens.json is generated by demo/seed.ts on first /demo-login hit.
# Including the host's stale copy in the image bypasses that flow and serves
# dead JWTs minted with an old JWT_SECRET. Always seed fresh in-container.
demo/demo-tokens.json
demo/.demo-state.json

# --- Macros + caches ---------------------------------------------------------
.DS_Store
Thumbs.db
__pycache__/
*.pyc
.pytest_cache
.cache

# --- Test + coverage ---------------------------------------------------------
coverage
.nyc_output

# --- Snapshots — manifests committed to repo, no need to bundle as build ctx -
docs/snapshots/*.md
!docs/snapshots/INDEX.md

# --- Logs / tmp --------------------------------------------------------------
*.log
.data
backups
