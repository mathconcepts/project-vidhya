# ============================================================
# EduGenius — AWS ECS Fargate Environment
# ============================================================
# Copy to .env.aws and fill in your values.
# Sensitive values (API keys, DB passwords) should be stored
# in AWS SSM Parameter Store or Secrets Manager, not here.
# Used by: deploy-aws.sh
# ============================================================

# ── AWS Account ───────────────────────────────────────────────
AWS_REGION=ap-south-1
AWS_ACCOUNT_ID=123456789012

# ── ECR / ECS Configuration ───────────────────────────────────
APP_NAME=edugenius
ECR_REPOSITORY=edugenius
ECS_CLUSTER=edugenius-cluster
ECS_SERVICE=edugenius-service
ECS_DESIRED_COUNT=1
IMAGE_TAG=latest

# ── Networking (VPC subnets & security groups) ────────────────
# Comma-separated. Leave empty to use default VPC.
ECS_SUBNETS=subnet-xxxxxxxxx,subnet-yyyyyyyyy
ECS_SECURITY_GROUPS=sg-xxxxxxxxx

# ── RDS Postgres ──────────────────────────────────────────────
# Store in SSM: /edugenius/DATABASE_URL
# aws ssm put-parameter --name /edugenius/DATABASE_URL \
#   --value "postgresql://user:pass@rds-endpoint:5432/edugenius" \
#   --type SecureString
RDS_INSTANCE_CLASS=db.t3.micro       # ~$25/month
# DATABASE_URL — stored in SSM, not here

# ── ElastiCache Redis ─────────────────────────────────────────
# Store in SSM: /edugenius/REDIS_URL
# REDIS_URL — stored in SSM, not here

# ── S3 Storage ────────────────────────────────────────────────
AWS_S3_BUCKET=edugenius-assets-123456789012
CLOUDFRONT_DISTRIBUTION_ID=EXXXXXXXXXX

# ── AI / LLM Keys ─────────────────────────────────────────────
# Store in SSM: /edugenius/GEMINI_API_KEY
# aws ssm put-parameter --name /edugenius/GEMINI_API_KEY \
#   --value "your_key" --type SecureString
GEMINI_API_KEY=store_in_ssm_not_here
ANTHROPIC_API_KEY=store_in_ssm_not_here

# ── Application ───────────────────────────────────────────────
NODE_ENV=production
LOG_LEVEL=info
CORS_ORIGIN=https://edugenius-ui.netlify.app
ENABLE_BATCH_RUNNER=true
