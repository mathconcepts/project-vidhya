# ============================================================
# EduGenius — Local Deployment Environment
# ============================================================
# Copy this to .env.local and fill in your values.
# Used by: docker-compose.yml + deploy-local.sh
# ============================================================

# ── Application ──────────────────────────────────────────────
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug
CORS_ORIGIN=http://localhost:5173

# ── Database (Docker Postgres — auto-configured) ─────────────
DATABASE_URL=postgresql://edugenius:edugenius@localhost:5432/edugenius

# ── Cache (Docker Redis — auto-configured) ───────────────────
REDIS_URL=redis://localhost:6379

# ── AI / LLM Keys ────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here     # Optional

# ── Feature Flags ─────────────────────────────────────────────
ENABLE_BATCH_RUNNER=true
BATCH_RUNNER_CRON=true

# ── Content & Storage (local paths) ──────────────────────────
CONTENT_STORAGE_PATH=./data
MEDIA_STORAGE_PATH=./data/media

# ── Email (optional for local dev) ───────────────────────────
# SMTP_HOST=localhost
# SMTP_PORT=1025           # MailHog default
# SMTP_USER=
# SMTP_PASS=

# ── Analytics (optional) ─────────────────────────────────────
# POSTHOG_API_KEY=
# GA4_MEASUREMENT_ID=
