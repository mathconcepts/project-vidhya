# ============================================================
# EduGenius — Hybrid Deployment Environment
# ============================================================
# Local backend + Supabase DB + Cloudinary/S3 media.
# Copy to .env.hybrid and fill in your values.
# Used by: deploy-hybrid.sh
# ============================================================

# ── Application ──────────────────────────────────────────────
NODE_ENV=production
PORT=3000
LOG_LEVEL=info
CORS_ORIGIN=https://edugenius-ui.netlify.app

# ── Supabase (managed Postgres) ──────────────────────────────
# Get from: https://app.supabase.io → Settings → API
SUPABASE_URL=https://tjcrhdavxkjjasfnrxtw.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_KEY=your_supabase_service_role_key_here
# Direct Postgres connection (for Prisma/pg)
DATABASE_URL=postgresql://postgres:your_db_password@db.tjcrhdavxkjjasfnrxtw.supabase.co:5432/postgres

# ── Cache (local Docker Redis) ────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── AI / LLM Keys ────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Media Storage — choose one ───────────────────────────────
# Option A: Cloudinary (recommended for images/video)
CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name

# Option B: AWS S3
# AWS_S3_BUCKET=edugenius-assets
# AWS_ACCESS_KEY_ID=your_access_key
# AWS_SECRET_ACCESS_KEY=your_secret_key
# AWS_REGION=ap-south-1

# ── Feature Flags ─────────────────────────────────────────────
ENABLE_BATCH_RUNNER=true
BATCH_RUNNER_CRON=true

# ── Email ─────────────────────────────────────────────────────
# SMTP_HOST=smtp.resend.com
# SMTP_PORT=465
# SMTP_USER=resend
# SMTP_PASS=your_resend_api_key
# EMAIL_FROM=noreply@edugenius.io

# ── Analytics ─────────────────────────────────────────────────
# POSTHOG_API_KEY=phc_...
